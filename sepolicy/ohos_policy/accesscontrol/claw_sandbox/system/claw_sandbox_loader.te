type claw_sandbox_exec, system_file_attr, exec_attr, file_attr;

domain_auto_transition_pattern(foundation, claw_sandbox_exec, claw_sandbox_loader);

# avc: denied { read write } comm="/system/bin/claw_sandbox" scontext=u:r:claw_sandbox_loader:s0 tcontext=u:object_r:bms_db_file:s0 tclass=file
allow claw_sandbox_loader bms_db_file:file { read write };

