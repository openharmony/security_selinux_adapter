debug_only(`
    domain_auto_transition_pattern(su, claw_sandbox_exec, claw_sandbox_loader);

    # avc: denied { use } comm="/system/bin/claw_sandbox" path="/unix/socket" scontext=u:r:claw_sandbox_loader:s0 tcontext=u:r:su:s0 tclass=fd
    allow claw_sandbox_loader su:fd { use };

    # avc: denied { read } comm="/system/bin/claw_sandbox" scontext=u:r:claw_sandbox_loader:s0 tcontext=u:r:su:s0 tclass=unix_stream_socket
    # avc: denied { write } comm="/system/bin/claw_sandbox" scontext=u:r:claw_sandbox_loader:s0 tcontext=u:r:su:s0 tclass=unix_stream_socket
    allow claw_sandbox_loader su:unix_stream_socket { read write };
')

neverallow { domain develop_domain debug_only(`-su') -foundation -claw_sandbox_loader } claw_sandbox_exec:file { execute };
